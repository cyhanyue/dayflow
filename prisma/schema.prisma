generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "linux-musl-openssl-3.0.x", "debian-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id                          String    @id @default(cuid())
  name                        String
  email                       String    @unique
  passwordHash                String
  profilePictureUrl           String?
  autoRolloverIncompleteTasks Boolean   @default(true)
  rolloverPosition            String    @default("bottom")
  theme                       String    @default("light")
  timeIncrement               Int       @default(5)
  hideCompletedTasksToday     Boolean   @default(false)
  autoArchiveAfterDays        Int       @default(4)
  calendarEventColoring       String    @default("by_channel")
  googleRefreshToken          String?
  googleAccessToken           String?
  googleTokenExpiry           DateTime?
  icalUrl                     String?
  createdAt                   DateTime  @default(now())
  updatedAt                   DateTime  @updatedAt

  contexts   Context[]
  channels   Channel[]
  tasks      Task[]
  calendars  Calendar[]
  events     CalendarEvent[]
  timeEntries TimeEntry[]
}

model Context {
  id        String    @id @default(cuid())
  userId    String
  name      String
  type      String    @default("work")
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  channels  Channel[]
}

model Channel {
  id        String    @id @default(cuid())
  userId    String
  contextId String?
  name      String
  color     String    @default("#6366f1")
  icon      String?
  isDefault Boolean   @default(false)
  sortOrder Int       @default(0)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  context Context? @relation(fields: [contextId], references: [id], onDelete: SetNull)
  tasks   Task[]
  events  CalendarEvent[]
}

model Task {
  id                     String    @id @default(cuid())
  userId                 String
  channelId              String?
  parentTaskId           String?
  title                  String
  notes                  String?
  status                 String    @default("incomplete")
  scheduledDate          String?
  startDate              String?
  dueDate                String?
  plannedTimeMinutes     Int?
  actualTimeMinutes      Int?
  timeboxStart           DateTime?
  timeboxEnd             DateTime?
  sortOrder              Float     @default(0)
  isRecurring            Boolean   @default(false)
  recurrenceRule         String?
  isBacklog              Boolean   @default(false)
  isArchived             Boolean   @default(false)
  consecutiveRolloverCount Int     @default(0)
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
  completedAt            DateTime?

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  channel     Channel?    @relation(fields: [channelId], references: [id], onDelete: SetNull)
  parentTask  Task?       @relation("subtasks", fields: [parentTaskId], references: [id], onDelete: SetNull)
  subtasks    Task[]      @relation("subtasks")
  timeEntries TimeEntry[]
}

model Calendar {
  id        String    @id @default(cuid())
  userId    String
  name      String
  color     String    @default("#3b82f6")
  isVisible Boolean   @default(true)
  isDefault Boolean   @default(false)
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  user   User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  events CalendarEvent[]
}

model CalendarEvent {
  id             String    @id @default(cuid())
  userId         String
  calendarId     String
  channelId      String?
  title          String
  description    String?
  location       String?
  startDatetime  DateTime
  endDatetime    DateTime
  isAllDay       Boolean   @default(false)
  color          String?
  recurrenceRule String?
  uid            String?   // iCal UID — used to detect moved events
  organizer      String?
  attendees      String[]  @default([])
  status         String    @default("confirmed")
  isCompleted    Boolean   @default(false)
  completedAt    DateTime?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  calendar  Calendar  @relation(fields: [calendarId], references: [id], onDelete: Cascade)
  channel   Channel?  @relation(fields: [channelId], references: [id], onDelete: SetNull)
}

model TimeEntry {
  id              String    @id @default(cuid())
  userId          String
  taskId          String
  startTime       DateTime
  endTime         DateTime?
  durationMinutes Int?
  createdAt       DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  task Task @relation(fields: [taskId], references: [id], onDelete: Cascade)
}

// Single-row table for cross-process timer state (floatie ↔ web app)
model TimerState {
  id                 String   @id @default("singleton")
  active             Boolean  @default(false)
  paused             Boolean  @default(false)
  timerStartedAt     Float?   // Unix ms timestamp (Float64 handles up to 2^53)
  timerAccumulatedMs Int      @default(0)
  title              String   @default("")
  plannedMins        Int?
  pendingAction      String?
  updatedAt          DateTime @updatedAt
}
